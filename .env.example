APP_NAME=SocialPulse
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://socialtoolsdev.test

# Detrás de Cloudflare Tunnel (local expuesto por HTTPS). Dejar vacío si no usas túnel.
# * = confiar en X-Forwarded-* del proxy (solo dev/staging).
TRUSTED_PROXIES=*

# OAuth vía túnel: overrides opcionales (si no se definen, se usa ${APP_URL}/connections/…/callback)
# META_REDIRECT_URI=https://tu-dominio-tunel/connections/meta/callback
# GOOGLE_REDIRECT_URI=https://tu-dominio-tunel/connections/google/callback
# TIKTOK_REDIRECT_URI=https://tu-dominio-tunel/connections/tiktok/callback
# LINKEDIN_REDIRECT_URI=https://tu-dominio-tunel/connections/linkedin/callback
# YOUTUBE_REDIRECT_URI=https://tu-dominio-tunel/connections/youtube/callback

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL (producción / staging). Para desarrollo local rápido: DB_CONNECTION=sqlite
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=socialpulse
DB_USERNAME=socialpulse
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@socialpulse.app"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

HORIZON_NAME="${APP_NAME}"

# OAuth / APIs (MVP — solicitar aprobaciones desde día 1)
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v22.0
META_REDIRECT_URI="${APP_URL}/connections/meta/callback"
# Meta Business Manager — System User (producción, token sin expiración)
META_SYSTEM_USER_ID=
META_SYSTEM_USER_ACCESS_TOKEN=
META_BUSINESS_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/connections/google/callback"
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI="${APP_URL}/connections/tiktok/callback"
TIKTOK_OAUTH_SCOPES=user.info.basic,video.list
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI="${APP_URL}/connections/linkedin/callback"
LINKEDIN_OAUTH_SCOPES=r_organization_admin,r_organization_social
LINKEDIN_API_VERSION=202405
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI="${APP_URL}/connections/youtube/callback"
YOUTUBE_OAUTH_SCOPES=https://www.googleapis.com/auth/youtube.readonly

# Observabilidad (producción / staging)
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE="${APP_VERSION}"
SENTRY_TRACES_SAMPLE_RATE=0.1
APP_VERSION=dev
LEGAL_CONTACT_EMAIL=privacy@socialpulse.app

VITE_APP_NAME="${APP_NAME}"
