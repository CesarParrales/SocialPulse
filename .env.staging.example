# SocialPulse — Staging (copiar a .env en servidor staging)
# cp .env.staging.example .env && php artisan key:generate

APP_NAME=SocialPulse
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_URL=https://staging.socialpulse.app
APP_VERSION=staging

APP_LOCALE=es
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=socialpulse_staging
DB_USERNAME=socialpulse
DB_PASSWORD=

SESSION_DRIVER=redis
CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_FROM_ADDRESS="hello@socialpulse.app"
MAIL_FROM_NAME="${APP_NAME}"

# OAuth — apps de desarrollo/staging (redirects deben coincidir con consolas de cada plataforma)
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v22.0
META_REDIRECT_URI="${APP_URL}/connections/meta/callback"
META_SYSTEM_USER_ID=
META_SYSTEM_USER_ACCESS_TOKEN=
META_BUSINESS_ID=

GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_REDIRECT_URI="${APP_URL}/connections/google/callback"

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI="${APP_URL}/connections/tiktok/callback"
TIKTOK_OAUTH_SCOPES=user.info.basic,video.list

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI="${APP_URL}/connections/linkedin/callback"
LINKEDIN_OAUTH_SCOPES=r_organization_admin,r_organization_social
LINKEDIN_API_VERSION=202405

YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI="${APP_URL}/connections/youtube/callback"
YOUTUBE_OAUTH_SCOPES=https://www.googleapis.com/auth/youtube.readonly

# Observabilidad
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=staging
SENTRY_RELEASE="${APP_VERSION}"
SENTRY_TRACES_SAMPLE_RATE=0.2

LEGAL_CONTACT_EMAIL=privacy@socialpulse.app

HORIZON_NAME="${APP_NAME} Staging"
